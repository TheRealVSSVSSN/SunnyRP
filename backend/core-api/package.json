{
    "name": "sunny-core-api",
    "version": "1.0.0",
    "description": "Sunny Roleplay Core API - Phase A (health/ready/metrics, env schema, PM2, logs, migrations)",
    "main": "src/server.js",
    "type": "module",
    "scripts": {
        "dev": "NODE_ENV=development node src/server.js",
        "start": "NODE_ENV=production node src/server.js",
        "pm2": "pm2 start pm2/ecosystem.config.js",
        "openapi:build": "node scripts/build-openapi.js",
        "lint": "bash scripts/lint-all.sh",
        "migrate:latest": "knex migrate:latest",
        "migrate:up": "knex migrate:up",
        "migrate:down": "knex migrate:down",
        "migrate:rollback": "knex migrate:rollback"
    },
    "dependencies": {
        "compression": "1.7.4",
        "cors": "2.8.5",
        "express": "4.19.2",
        "express-prom-bundle": "7.1.0",
        "helmet": "7.1.0",
        "hpp": "0.2.3",
        "ip": "2.0.1",
        "knex": "3.1.0",
        "mysql2": "3.11.0",
        "pino": "9.4.0",
        "pino-http": "9.0.0",
        "uuid": "9.0.1",
        "zod": "3.23.8",
        "rate-limiter-flexible": "5.0.3"
    },
    "devDependencies": {
        "pm2": "5.4.3"
    }
}