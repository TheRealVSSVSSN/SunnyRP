                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"primary\": \"license\",\n  \"ip\": \"{{ip}}\",\n  \"identifiers\": {\n    \"license\": \"{{licenseId}}\",\n    \"discord\": \"{{discordId}}\",\n    \"steam\": \"{{steamId}}\",\n    \"fivem\": \"{{fivemId}}\",\n    \"ip\": \"{{ip}}\"\n  }\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
