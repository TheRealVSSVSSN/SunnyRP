                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "",
                                    "pm.test(\"Link 200\", function () { pm.response.to.have.status(200); });",
                                    "var json = pm.response.json();",
                                    "pm.expect(json.ok).to.be.true;",
                                    "pm.expect(json.data).to.have.property('user');",
                                    "pm.collectionVariables.set(\"userId\", json.data.user.id);",
                                    "console.log(\"userId set to\", json.data.user.id);"
                                ]
                            }
