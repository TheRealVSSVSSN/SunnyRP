{
    "info": {
        "name": "SunnyRP - srp-base",
        "_postman_id": "6c1c3c9d-7a7a-4f5f-a1bb-111122223333",
        "description": "SunnyRP Base API collection (health, config, permissions, users, characters).",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "variable": [
        {
            "key": "baseUrl",
            "value": "http://127.0.0.1:3010"
        },
        {
            "key": "token",
            "value": "CHANGE-ME"
        },
        {
            "key": "hex",
            "value": "license:test123"
        }
    ],
    "item": [
        {
            "name": "Health",
            "request": {
                "method": "GET",
                "url": "{{baseUrl}}/v1/healthz",
                "header": [
                    {
                        "key": "X-API-Token",
                        "value": "{{token}}"
                    }
                ]
            }
        },
        {
            "name": "Config Live - GET",
            "request": {
                "method": "GET",
                "url": "{{baseUrl}}/v1/config/live",
                "header": [
                    {
                        "key": "X-API-Token",
                        "value": "{{token}}"
                    }
                ]
            }
        },
        {
            "name": "Permissions - GET",
            "request": {
                "method": "GET",
                "url": "{{baseUrl}}/v1/permissions/1",
                "header": [
                    {
                        "key": "X-API-Token",
                        "value": "{{token}}"
                    }
                ]
            }
        },
        {
            "name": "Users - exists",
            "request": {
                "method": "GET",
                "url": "{{baseUrl}}/v1/users/exists?hex_id={{hex}}",
                "header": [
                    {
                        "key": "X-API-Token",
                        "value": "{{token}}"
                    }
                ]
            }
        },
        {
            "name": "Users - create (idempotent)",
            "request": {
                "method": "POST",
                "url": "{{baseUrl}}/v1/users",
                "header": [
                    {
                        "key": "X-API-Token",
                        "value": "{{token}}"
                    },
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\"hex_id\":\"{{hex}}\",\"name\":\"Test User\",\"identifiers\":[{\"type\":\"license\",\"value\":\"{{hex}}\"}]}"
                }
            }
        },
        {
            "name": "Users - get",
            "request": {
                "method": "GET",
                "url": "{{baseUrl}}/v1/users/{{hex}}",
                "header": [
                    {
                        "key": "X-API-Token",
                        "value": "{{token}}"
                    }
                ]
            }
        },
        {
            "name": "Characters - list",
            "request": {
                "method": "GET",
                "url": "{{baseUrl}}/v1/characters?owner_hex={{hex}}",
                "header": [
                    {
                        "key": "X-API-Token",
                        "value": "{{token}}"
                    }
                ]
            }
        },
        {
            "name": "Characters - create",
            "request": {
                "method": "POST",
                "url": "{{baseUrl}}/v1/characters",
                "header": [
                    {
                        "key": "X-API-Token",
                        "value": "{{token}}"
                    },
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\"owner_hex\":\"{{hex}}\",\"first_name\":\"Jordan\",\"last_name\":\"Avery\"}"
                }
            }
        },
        {
            "name": "Characters - delete",
            "request": {
                "method": "DELETE",
                "url": "{{baseUrl}}/v1/characters/1",
                "header": [
                    {
                        "key": "X-API-Token",
                        "value": "{{token}}"
                    }
                ]
            }
        }
    ]
}