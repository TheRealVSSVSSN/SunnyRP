PORT=3301
API_TOKEN=change_me_base_api_only

# Security / replay guard
ENABLE_REPLAY_GUARD=true
REPLAY_ALLOWED_SKEW_SECONDS=90
REDIS_URL=redis://127.0.0.1:6379

# Observability
ENABLE_METRICS=true
LOG_LEVEL=info

# MySQL connection (required for Phase B)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=srp
DB_PASSWORD=srp_password
DB_NAME=srp_base
DB_CONN_LIMIT=10

# Rate limits (per window)
RATE_LIMIT_WINDOW_SEC=60
RATE_LIMIT_MAX_BAN=10
RATE_LIMIT_MAX_PERMISSIONS=60
RATE_LIMIT_MAX_AUDIT_READ=120
RATE_LIMIT_MAX_ADMIN_READ=120

# IP allowlist (optional). Enable + comma-separated list of allowed IPs.
ENABLE_IP_ALLOWLIST=false
ALLOWLIST_IPS=127.0.0.1,::1

# Reverse proxy awareness (for real client IPs)
TRUST_PROXY=false

# Idempotency for mutating POSTs (ttl in seconds)
IDEMPOTENCY_TTL_SEC=600

# Live config write (toggle)
ENABLE_CONFIG_WRITE=false

# Feature & scopes caches
FEATURE_CACHE_TTL_SEC=10
SCOPES_CACHE_TTL_SEC=30
SCOPES_CACHE_USE_REDIS=true

# Outbox worker
ENABLE_OUTBOX_WORKER=false
OUTBOX_BATCH_SIZE=50
OUTBOX_CLAIM_TIMEOUT_SEC=60
OUTBOX_INTERVAL_MS=1000
OUTBOX_DELIVERY_URL=
OUTBOX_REDIS_CHANNEL_PREFIX=srp:outbox:

# HTTP client defaults (used by internal deliveries)
HTTP_TIMEOUT_MS=3000
HTTP_RETRY_COUNT=2