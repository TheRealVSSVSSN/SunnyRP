# ---- CORE-API ENV ----
NODE_ENV=development
PORT=3301
API_TOKEN=changeme_please
ALLOWLIST_IPS=127.0.0.1,::1
LOG_JSON=true
LOG_LEVEL=info
LOG_DIR=./logs
REQUEST_RATE_WINDOW_MS=60000
REQUEST_RATE_MAX=600
METRICS_USERNAME= # optional basic auth if you want, leave blank to disable
METRICS_PASSWORD=

# MySQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=secret
DB_NAME=srp_core

# HMAC (optional, can be empty to disable)
HMAC_SECRET=

ECON_TREASURY_ACCOUNT_ID=gov:treasury

REPLAY_TTL_SECONDS=30
REPLAY_ALLOWED_SKEW_SECONDS=20
BURST_WINDOW_MS=10000
BURST_MAX_PER_WINDOW=240
ENABLE_REPLAY_GUARD=true
