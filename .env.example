# Service
PORT=3010
API_TOKEN=CHANGE-ME
TRUST_PROXY=1

# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=sunnyrp
DB_USER=sunnyrp
DB_PASS=sunnyrp-password

# Security
ENABLE_REPLAY_GUARD=0
REPLAY_TTL_SEC=90
ENABLE_IP_ALLOWLIST=0
IP_ALLOWLIST=127.0.0.1/32

# Metrics
ENABLE_METRICS=1

# Feature toggles (fallbacks; live flags take precedence)
FEATURE_USERS=1
FEATURE_CHARACTERS=1

# Optional Redis (if used by other features)
REDIS_URL=